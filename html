<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>APIC Event</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
:root {
 --primary:#1f2f3a;
 --secondary:#2e4a5a;
 --accent:#4fa3d1;
 --light-bg:#f5f7f9;
 --white:#ffffff;
 --text-dark:#2b2b2b;
 --text-muted:#6b7280;
 --border:#e5e7eb;
}

/* GLOBAL RESET */
*{
 box-sizing:border-box;
 margin:0;
 padding:0;
}

body{
 font-family:'Inter','Helvetica Neue',Arial,sans-serif;
 color:var(--text-dark);
 background:var(--white);
 line-height:1.6;
 -webkit-font-smoothing:antialiased;
}

h1{
 font-size:48px;
 font-weight:700;
 letter-spacing:-0.02em;
 margin-bottom:16px;
}

h2{
 font-size:32px;
 font-weight:600;
 margin-bottom:16px;
}

h3{
 font-size:22px;
 font-weight:600;
 margin-bottom:16px;
}

p{
 font-size:16px;
 color:var(--text-muted);
 line-height:1.6;
 margin-bottom:16px;
}

/* HEADER (match APIC commercial style) */
.site-header{
 position:sticky;
 top:0;
 z-index:1000;
}

.utility-bar{
 background:#d5d8dd;
 border-bottom:1px solid #c6cad1;
}

.utility-inner{
 max-width:1200px;
 margin:0 auto;
 padding:10px 24px;
 display:flex;
 justify-content:flex-end;
 gap:10px;
}

.utility-link{
 background:#676a70;
 color:var(--white);
 text-decoration:none;
 padding:8px 16px;
 border-radius:4px;
 font-size:15px;
 font-weight:500;
}

.utility-link:hover{
 background:#555960;
 color:var(--white);
}

.navbar{
 background:#1182bd;
}

.nav-inner{
 max-width:1200px;
 margin:0 auto;
 padding:14px 24px;
 display:flex;
 justify-content:space-between;
 align-items:center;
}

.logo{
 display:flex;
 align-items:center;
 height:58px;
}

.logo img{
 height:58px;
 width:auto;
 object-fit:contain;
}

.nav-links{
 display:flex;
 align-items:center;
}

.nav-links a{
 margin-left:24px;
 text-decoration:none;
 color:var(--white);
 font-size:14px;
 font-weight:500;
 line-height:1;
}

.nav-links a:hover{
 color:#d8effa;
}

@media (max-width:1200px){
 .logo img{
  height:46px;
 }

 .nav-links a{
  font-size:13px;
  margin-left:16px;
 }
}

@media (max-width:900px){
 .utility-inner{
  justify-content:center;
  flex-wrap:wrap;
 }

 .nav-inner{
  flex-direction:column;
  gap:12px;
 }

 .nav-links{
  flex-wrap:wrap;
  justify-content:center;
 }

 .nav-links a{
  font-size:13px;
  margin:0 10px;
 }
}

/* LAYOUT */
.container{
 max-width:1200px;
 margin:0 auto;
 padding:0 24px;
}

.section{
 padding:80px 0;
}

.section-light{
 background:var(--light-bg);
}

.section-dark{
 background:var(--primary);
 color:var(--white);
}

/* HERO (very specific spacing) */
.hero{
 padding:120px 0;
}

.hero h1{
 max-width:700px;
 color:var(--primary);
}

.hero p{
 max-width:520px;
 margin-bottom:34px;
}

/* BUTTONS */
.btn{
 display:inline-block;
 padding:14px 28px;
 border-radius:4px;
 font-weight:600;
 font-size:14px;
 text-decoration:none;
 cursor:pointer;
 transition:all .2s ease;
}

.btn-primary{
 background:var(--accent);
 color:#fff;
 border:0;
}

.btn-primary:hover{
 background:#3b8bb5;
 transform:translateY(-2px);
}

.btn-outline{
 display:inline-block;
 border:2px solid var(--primary);
 color:var(--primary);
 padding:12px 26px;
 border-radius:4px;
 text-decoration:none;
 font-weight:600;
}

/* GRID */
.grid{
 display:grid;
 grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
 gap:28px;
 margin-top:60px;
}

/* CARDS (THIS IS WHERE APIC FEEL COMES FROM) */
.card{
 background:#fff;
 border:1px solid var(--border);
 padding:32px;
 border-radius:6px;
 transition:all .3s ease;
}

.card:hover{
 transform:translateY(-6px);
 box-shadow:0 10px 30px rgba(0,0,0,0.08);
}

.card h3{
 margin-bottom:12px;
 color:var(--primary);
 font-size:18px;
}

.card ul{
 list-style:none;
 margin:16px 0 26px;
}

.card li{
 color:var(--text-muted);
 margin-bottom:8px;
 font-size:14.5px;
}

/* FEATURED CARD (subtle emphasis, not loud) */
.featured{
 border-top:3px solid var(--accent);
}

.badge{
 font-size:11px;
 font-weight:700;
 color:var(--accent);
 margin-bottom:8px;
 letter-spacing:.6px;
 text-transform:uppercase;
}

/* LOGO STRIP (very subtle like APIC) */
.logos{
 text-align:center;
 margin-top:70px;
 padding-top:30px;
 border-top:1px solid var(--border);
}

.logos p{
 font-size:13px;
 color:var(--text-muted);
 margin-bottom:18px;
}

.logo-row{
 display:flex;
 justify-content:center;
 flex-wrap:wrap;
 gap:36px;
}

.logo-row img{
 height:32px;
 opacity:.55;
 transition:.2s;
}

.logo-row img:hover{
 opacity:.9;
}

/* DROPDOWN */
.dropdown{
 text-align:center;
 margin-top:70px;
}

select{
 padding:12px 16px;
 border-radius:6px;
 border:1px solid var(--border);
 font-size:14px;
 font-weight:500;
 margin-right:10px;
 background:#fff;
 color:var(--text-dark);
 cursor:pointer;
 transition:all .2s ease;
}

select:hover{
 border-color:var(--accent);
}

select:focus{
 outline:none;
 border-color:var(--accent);
 box-shadow:0 0 0 3px rgba(79,163,209,0.2);
}

button{
 border:none;
}

/* MICRO INTERACTIONS */
a, button, select, .card{
 transition:all .2s ease;
}

</style>
</head>

<body>

<!-- HEADER -->
<header class="site-header">
  <div class="utility-bar">
    <div class="utility-inner">
      <a href="#" class="utility-link">Locations</a>
      <a href="#" class="utility-link">Contact</a>
      <a href="#" class="utility-link">Request Service</a>
    </div>
  </div>

  <div class="navbar">
    <div class="nav-inner">
      <div class="logo">
        <img src="https://apicmsi.com/wp-content/uploads/2026/01/WebsiteLogoWhite.png" alt="APIC Solutions">
      </div>
      <nav class="nav-links" aria-label="Primary">
        <a href="#">Home</a>
        <a href="#">About APIC ▾</a>
        <a href="#">What We Do ▾</a>
        <a href="#">Industries We Help ▾</a>
      </nav>
    </div>
  </div>
</header>

<!-- HERO -->
<div class="section">
  <div class="container hero">
    <h1>Power the Future. Secure Your Spot.</h1>
    <p>
      Join leaders in electrical, security, and infrastructure. 
      Build partnerships that scale through fully integrated systems and proven performance.
    </p>
    <a href="#" class="btn btn-primary">Register Now</a>
  </div>
</div>

<!-- SPONSOR SECTION -->
<div class="section section-light">
  <div class="container">

    <div class="grid">

      <div class="card featured">
        <div class="badge">MOST POPULAR</div>
        <h3>Platinum Sponsor</h3>
        <ul>
          <li>Premium logo placement</li>
          <li>Speaking opportunity</li>
          <li>Maximum exposure</li>
        </ul>
        <a href="#" class="btn btn-primary">Become Platinum</a>
      </div>

      <div class="card">
        <h3>Gold Sponsor</h3>
        <ul>
          <li>High visibility branding</li>
          <li>Event recognition</li>
        </ul>
        <a href="#" class="btn btn-primary">Become Gold</a>
      </div>

      <div class="card">
        <h3>Silver Sponsor</h3>
        <ul>
          <li>Logo placement</li>
          <li>Brand exposure</li>
        </ul>
        <a href="#" class="btn btn-primary">Become Silver</a>
      </div>

      <div class="card">
        <h3>Bronze Sponsor</h3>
        <ul>
          <li>Event listing</li>
          <li>Entry-level exposure</li>
        </ul>
        <a href="#" class="btn btn-primary">Become Bronze</a>
      </div>

    </div>

    <!-- TRUST STRIP -->
    <div class="logos">
      <p>Trusted by Industry Leaders</p>
      <div class="logo-row">
        <img src="https://via.placeholder.com/120x40?text=Logo">
        <img src="https://via.placeholder.com/120x40?text=Logo">
        <img src="https://via.placeholder.com/120x40?text=Logo">
        <img src="https://via.placeholder.com/120x40?text=Logo">
      </div>
    </div>

    <!-- DROPDOWN -->
    <div class="dropdown">
      <select id="select">
        <option value="">Select Participation Type</option>
        <option value="attendee">Attendee</option>
        <option value="platinum">Platinum</option>
        <option value="gold">Gold</option>
        <option value="silver">Silver</option>
        <option value="bronze">Bronze</option>
      </select>
      <button onclick="goToPayment()" class="btn btn-primary">Continue</button>
    </div>

  </div>
</div>

<script>
function goToPayment(){
  const links = {
    attendee:"#",
    platinum:"#",
    gold:"#",
    silver:"#",
    bronze:"#"
  };

  const val = document.getElementById("select").value;
  if(links[val]) window.location.href = links[val];
}
</script>

</body>
</html>


